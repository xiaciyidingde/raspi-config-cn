get_overlay_now() {
  grep -q "overlayroot=tmpfs" /proc/cmdline
  echo $?
}

get_overlay_conf() {
  grep -q "overlayroot=tmpfs" $CMDLINE
  echo $?
}

get_bootro_now() {
  findmnt /boot${FIRMWARE} | grep -q " ro,"
  echo $?
}

get_bootro_conf() {
  grep /boot${FIRMWARE} /etc/fstab | grep -q "defaults.*,ro[ ,]"
  echo $?
}

is_uname_current() {
  test -d "/lib/modules/$(uname -r)"
}

enable_overlayfs() {
  if [ "$(awk '/MemTotal/{print $2; exit}' /proc/meminfo)" -le 262144 ]; then
    if [ "$INTERACTIVE" = True ]; then
      whiptail --msgbox "建议至少 512MB 的 RAM 用于覆盖文件系统" 20 60 1
    else
      echo "建议至少 512MB 的 RAM 用于覆盖文件系统"
    fi
    return 1
  fi
  is_installed overlayroot || apt-get install -y overlayroot
  # 如果启动分区尚未可写，则将其挂载为可写
  if [ $(get_bootro_now) -eq 0 ] ; then
    if ! mount -o remount,rw /boot${FIRMWARE} 2>/dev/null ; then
      echo "无法将启动分区挂载为可写 - 无法启用"
      return 1
    fi
    BOOTRO=yes
  else
    BOOTRO=no
  fi

  # 修改命令行
  if ! grep -q "overlayroot=tmpfs" $CMDLINE ; then
    sed -i $CMDLINE -e "s/^/overlayroot=tmpfs /"
  fi

  if [ "$BOOTRO" = "yes" ] ; then
    if ! mount -o remount,ro /boot${FIRMWARE} 2>/dev/null ; then
      echo "无法将启动分区重新挂载为只读"
    fi
  fi
}

disable_overlayfs() {
  # 如果启动分区尚未可写，则将其挂载为可写
  if [ $(get_bootro_now) -eq 0 ] ; then
    if ! mount -o remount,rw /boot${FIRMWARE} 2>/dev/null ; then
      echo "无法将启动分区挂载为可写 - 无法禁用"
      return 1
    fi
    BOOTRO=yes
  else
    BOOTRO=no
  fi


  # 修改命令行
  sed -i $CMDLINE -e "s/\(.*\)overlayroot=tmpfs \(.*\)/\1\2/"

  if [ "$BOOTRO" = "yes" ] ; then
    if ! mount -o remount,ro /boot${FIRMWARE} 2>/dev/null ; then
      echo "无法将启动分区重新挂载为只读"
    fi
  fi
}

enable_bootro() {
  if [ $(get_overlay_now) -eq 0 ] ; then
    echo "覆盖正在使用；无法更新 fstab"
    return 1
  fi
  sed -i /etc/fstab -e "s#\(.*/boot$FIRMWARE.*\)defaults\(.*\)#\1defaults,ro\2#"
}

disable_bootro() {
  if [ $(get_overlay_now) -eq 0 ] ; then
    echo "覆盖正在使用；无法更新 fstab"
    return 1
  fi
  sed -i /etc/fstab -e "s#\(.*/boot$FIRMWARE.*\)defaults,ro\(.*\)#\1defaults\2#"
}

do_overlayfs() {
  DEFAULT=--defaultno
  CURRENT=0
  STATUS="已禁用"

  if [ "$INTERACTIVE" = True ] && ! is_uname_current; then
    whiptail --msgbox "找不到正在运行的内核 ($(uname -r)) 的模块。" 20 60 1
    return 1
  fi

  if [ $(get_overlay_conf) -eq 0 ] ; then
    DEFAULT=
    CURRENT=1
    STATUS="已启用"
  fi
  if [ "$INTERACTIVE" = True ]; then
    whiptail --yesno "您想启用覆盖文件系统吗？" $DEFAULT 20 60 2
    RET=$?
  else
    RET=$1
  fi
  if [ $RET -eq $CURRENT ]; then
    if [ $RET -eq 0 ]; then
      if enable_overlayfs; then
        STATUS="已启用"
        ASK_TO_REBOOT=1
      else
        STATUS="未更改"
      fi
    elif [ $RET -eq 1 ]; then
      if disable_overlayfs; then
        STATUS="已禁用"
        ASK_TO_REBOOT=1
      else
        STATUS="未更改"
      fi
    else
      return $RET
    fi
  fi
  if [ "$INTERACTIVE" = True ]; then
    whiptail --msgbox "覆盖文件系统已$STATUS。" 20 60 1
  fi
  if [ $(get_overlay_now) -eq 0 ] ; then
    if [ $(get_bootro_conf) -eq 0 ] ; then
      BPRO="只读"
    else
      BPRO="可写"
    fi
    if [ "$INTERACTIVE" = True ]; then
      whiptail --msgbox "启动分区当前为$BPRO。启用覆盖文件系统时无法更改此设置。" 20 60 1
    fi
  else
    DEFAULT=--defaultno
    CURRENT=0
    STATUS="可写"
    if [ $(get_bootro_conf) -eq 0 ]; then
      DEFAULT=
      CURRENT=1
      STATUS="只读"
    fi
    if [ "$INTERACTIVE" = True ]; then
      whiptail --yesno "您想对启动分区进行写保护吗？" $DEFAULT 20 60 2
      RET=$?
    else
      RET=$1
    fi
    if [ $RET -eq $CURRENT ]; then
      if [ $RET -eq 0 ]; then
        if enable_bootro; then
          STATUS="只读"
          ASK_TO_REBOOT=1
        else
          STATUS="未更改"
        fi
      elif [ $RET -eq 1 ]; then
        if disable_bootro; then
          STATUS="可写"
          ASK_TO_REBOOT=1
        else
          STATUS="未更改"
        fi
      else
        return $RET
      fi
    fi
    if [ "$INTERACTIVE" = True ]; then
      whiptail --msgbox "启动分区为$STATUS。" 20 60 1
    fi
  fi
}

get_proxy() {
  SCHEME="$1"

  VAR_NAME="${SCHEME}_proxy"
  if [ -f /etc/profile.d/proxy.sh ]; then
    # shellcheck disable=SC1091
    . /etc/profile.d/proxy.sh
  fi
  eval "echo \$VAR_NAME"
}

do_proxy() {
  SCHEMES="$1"
  ADDRESS="$2"
  if [ "$SCHEMES" = "all" ]; then
    CURRENT="$(get_proxy http)"
    SCHEMES="http https ftp rsync"
  else
    CURRENT="$(get_proxy "$SCHEMES")"
  fi
  if [ "$INTERACTIVE" = True ]; then
    if [ "$SCHEMES" = "no" ]; then
      STRING="请输入应排除使用代理服务器的地址列表（用逗号分隔）。\\n例如：localhost,127.0.0.1,localaddress,.localdomain.com"
    else
      STRING="请输入代理地址。\\n例如：http://user:pass@proxy:8080"
    fi
    if ! ADDRESS="$(whiptail --inputbox "$STRING"  20 60 "$CURRENT" 3>&1 1>&2 2>&3)"; then
      return 0
    fi
  fi
  for SCHEME in $SCHEMES; do
    unset "${SCHEME}_proxy"
    CURRENT="$(get_proxy "$SCHEME")"
    if [ "$CURRENT" != "$ADDRESS" ]; then
      ASK_TO_REBOOT=1
    fi
    if [ -f /etc/profile.d/proxy.sh ]; then
      sed -i "/^export ${SCHEME}_/Id" /etc/profile.d/proxy.sh
    fi
    if [ "${SCHEME#*http}" != "$SCHEME" ]; then
      if [ -f /etc/apt/apt.conf.d/01proxy ]; then
        sed -i "/::${SCHEME}::Proxy/d" /etc/apt/apt.conf.d/01proxy
      fi
    fi
    if [ -z "$ADDRESS" ]; then
      STATUS=已清除
      continue
    fi
    STATUS=已更新
    SCHEME_UPPER="$(echo "$SCHEME" | tr '[:lower:]' '[:upper:]')"
    echo "export ${SCHEME_UPPER}_PROXY=\"$ADDRESS\"" >> /etc/profile.d/proxy.sh
    if [ "$SCHEME" != "rsync" ]; then
      echo "export ${SCHEME}_proxy=\"$ADDRESS\"" >> /etc/profile.d/proxy.sh
    fi
    if [ "${SCHEME#*http}" != "$SCHEME" ]; then
      echo "Acquire::$SCHEME::Proxy \"$ADDRESS\";"  >> /etc/apt/apt.conf.d/01proxy
    fi
  done
  if [ "$INTERACTIVE" = True ]; then
    whiptail --msgbox "代理设置已$STATUS" 20 60 1
  fi
}

