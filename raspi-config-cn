        3>&1 1>&2 2>&3)
    else
      FUN=$(whiptail --title "树莓派软件配置工具 (raspi-config)" --menu "设置选项" $WT_HEIGHT $WT_WIDTH $WT_MENU_HEIGHT --cancel-button 完成 --ok-button 选择 \
        "1 系统选项" "配置系统设置" \
        "2 显示选项" "配置显示设置" \
        "3 接口选项" "配置外设连接" \
        "5 本地化选项" "配置语言和区域设置" \
        "6 高级选项" "配置高级设置" \
        "8 更新" "将此工具更新到最新版本" \
        "9 关于 raspi-config" "关于此配置工具的信息" \
        3>&1 1>&2 2>&3)
    fi
    RET=$?
    if [ $RET -eq 1 ]; then
      do_finish
    elif [ $RET -eq 0 ]; then
      case "$FUN" in
        1\ *) do_system_menu ;;
        2\ *) do_display_menu ;;
        3\ *) do_interface_menu ;;
        4\ *) do_performance_menu ;;
        5\ *) do_internationalisation_menu ;;
        6\ *) do_advanced_menu ;;
        8\ *) do_update ;;
        9\ *) do_about ;;
        *) whiptail --msgbox "程序员错误：无法识别的选项" 20 60 1 ;;
      esac || whiptail --msgbox "运行选项 $FUN 时出错" 20 60 1
    else
      exit 1
    fi
  done
fi
