      fi
      FUN=$(whiptail --title "树莓派软件配置工具 (raspi-config)" --backtitle "$(cat /proc/device-tree/model), ${FMEMSIZE}" --menu "设置选项" $WT_HEIGHT $WT_WIDTH $WT_MENU_HEIGHT --cancel-button 完成 --ok-button 选择 \
