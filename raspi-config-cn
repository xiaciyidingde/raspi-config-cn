  fi
  if [ "$INTERACTIVE" = True ]; then
    whiptail --yesno \
      "您想启用管理员 (sudo) 密码吗？" \
      $DEFAULT 20 60 2
    RET=$?
  else
    RET=$1
  fi
  if [ "$RET" -eq 0 ]; then
    if [ -e $PSFILE ] ; then rm $PSFILE ; fi
    if [ -e $GPSFILE ] ; then rm $GPSFILE ; fi
    if [ -e $CIFILE ] ; then rm $CIFILE ; fi
