do_sudo_pass() {
  PSFILE="/etc/sudoers.d/010_$USER-nopasswd"
  GPSFILE="/etc/sudoers.d/010_pi-nopasswd"
  CIFILE="/etc/sudoers.d/90-cloud-init-users"
