do_journald_storage() {
  if [ "$INTERACTIVE" = True ]; then
    RES=$(whiptail --title "树莓派软件配置工具 (raspi-config)" --menu "选择日志位置" "$WT_HEIGHT" "$WT_WIDTH" "$WT_MENU_HEIGHT" \
      "1" "默认" \
      "2" "易失性" \
      "3" "持久性" \
      "4" "自动" \
      "5" "无" \
      3>&1 1>&2 2>&3)
  else
    RES=""
    true
  fi
  # shellcheck disable=SC2181
  if [ $? -eq 0 ]; then
    case $RES in
      2) JSTRING="volatile"
      ;;
      3) JSTRING="persistent"
      ;;
      4) JSTRING="auto"
      ;;
      5) JSTRING="none"
      ;;
      *) JSTRING=""
      ;;
    esac

    # 将基本配置文件中的任何先前配置恢复为
    # 注释掉的 systemd 默认值，因为我们现在使用插入式配置
    sed -i -E 's/^(Storage)=.*/#\1=auto/' /etc/systemd/journald.conf 2>/dev/null || true

    CONFIG_FILE="/etc/systemd/journald.conf.d/80-raspi-config-journal-storage.conf"

    if [ -n "$JSTRING" ]; then
      # 如果目录不存在则创建
      mkdir -p /etc/systemd/journald.conf.d
      # 创建带有设置的配置文件
      cat > "$CONFIG_FILE" << EOF
# 由 raspi-config 创建/管理

[Journal]
Storage=$JSTRING
EOF
    else
      # 如果存在则删除我们的配置文件
      if [ -e "$CONFIG_FILE" ]; then
        rm -f "$CONFIG_FILE"
        # 如果为空则尝试删除目录
        rmdir --ignore-fail-on-non-empty /etc/systemd/journald.conf.d 2>/dev/null
      fi
    fi

    if [ "$INTERACTIVE" = True ]; then
      whiptail --msgbox "日志位置已设置为 ${JSTRING:-默认}" 20 60 1
    fi
  fi
}

