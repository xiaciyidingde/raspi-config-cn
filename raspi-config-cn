do_audio() {
  if is_pulseaudio ; then
    whiptail --msgbox "当使用 PulseAudio 或 PipeWire 时，raspi-config 无法配置音频。\n\n这些可以通过任务栏插件控制。" 20 60 1
    return 0
  else
    if aplay -l | grep -q "bcm2835 ALSA"; then
      if [ "$INTERACTIVE" = True ]; then
        AUDIO_OUT=$(whiptail --menu "选择音频输出" 20 60 10 \
          "0" "自动" \
          "1" "强制 3.5mm（'耳机'）插孔" \
          "2" "强制 HDMI" \
          3>&1 1>&2 2>&3)
      else
        AUDIO_OUT=$1
      fi
      if [ "$?" -eq 0 ] && [ -n "$AUDIO_OUT" ]; then
        amixer cset numid=3 "$AUDIO_OUT"
      fi
    else
      ASPATH=$(getent passwd $USER | cut -d : -f 6)/.asoundrc
      if [ "$INTERACTIVE" = True ]; then
        n=0
        array=""
        while [ $n -le 9 ]
        do
          CARD=$(LC_ALL=C aplay -l | grep "card $n" | cut -d [ -f 2 | cut -d ] -f 1)
          if [ -z "$CARD" ] ; then
            break
          else
            if [ -z "$array" ] ; then
              array=$n"/"$CARD
            else
              #shellcheck disable=2027
              array=$array"/"$n"/"$CARD
            fi
          fi
          n=$(( n+1 ))
        done
        if [ $n -eq 0 ] ; then
          whiptail --msgbox "未找到音频设备" 20 60 1
          false
        else
          oIFS="$IFS"
          IFS="/"
          AUDIO_OUT=$(whiptail --menu "选择音频输出" 20 60 10 ${array} 3>&1 1>&2 2>&3)
          IFS="$oIFS"
        fi
      else
        AUDIO_OUT=$1
      fi
      if [ "$?" -eq 0 ] && [ -n "$AUDIO_OUT" ]; then
        cat << EOF > $ASPATH
pcm.!default {
  type asym
  playback.pcm {
    type plug
    slave.pcm "output"
  }
  capture.pcm {
    type plug
    slave.pcm "input"
  }
}

pcm.output {
  type hw
  card $AUDIO_OUT
}

ctl.!default {
  type hw
  card $AUDIO_OUT
}
EOF
      fi
    fi
  fi
}

do_resolution() {
  if [ "$INTERACTIVE" = True ]; then
    CMODE=$(get_config_var hdmi_mode $CONFIG)
    CGROUP=$(get_config_var hdmi_group $CONFIG)
    if [ $CMODE -eq 0 ] ; then
      CSET="默认"
    elif [ $CGROUP -eq 2 ] ; then
      CSET="DMT 模式 "$CMODE
    else
      CSET="CEA 模式 "$CMODE
    fi
    oIFS="$IFS"
    IFS="/"
    if tvservice -d /dev/null | grep -q Nothing ; then
      value="默认/720x480/DMT 模式 4/640x480 60Hz 4:3/DMT 模式 9/800x600 60Hz 4:3/DMT 模式 16/1024x768 60Hz 4:3/DMT 模式 85/1280x720 60Hz 16:9/DMT 模式 35/1280x1024 60Hz 5:4/DMT 模式 51/1600x1200 60Hz 4:3/DMT 模式 82/1920x1080 60Hz 16:9/"
    else
      value="默认/显示器首选分辨率/"
      value=$value$(tvservice -m CEA | grep progressive | cut -b 12- | sed 's/mode \([0-9]\+\): \([0-9]\+\)x\([0-9]\+\) @ \([0-9]\+\)Hz \([0-9]\+\):\([0-9]\+\), clock:[0-9]\+MHz progressive/CEA 模式 \1\/\2x\3 \4Hz \5:\6/' | tr '\n' '/')
      value=$value$(tvservice -m DMT | grep progressive | cut -b 12- | sed 's/mode \([0-9]\+\): \([0-9]\+\)x\([0-9]\+\) @ \([0-9]\+\)Hz \([0-9]\+\):\([0-9]\+\), clock:[0-9]\+MHz progressive/DMT 模式 \1\/\2x\3 \4Hz \5:\6/' | tr '\n' '/')
    fi
    RES=$(whiptail --default-item $CSET --menu "选择屏幕分辨率" 20 60 10 ${value} 3>&1 1>&2 2>&3)
    STATUS=$?
    IFS="$oIFS"
    if [ $STATUS -eq 0 ] ; then
      GRS=$(echo "$RES" | cut -d ' ' -f 1)
      MODE=$(echo "$RES" | cut -d ' ' -f 3)
      if [ $GRS = "默认" ] ; then
        MODE=0
      elif [ $GRS = "DMT" ] ; then
        GROUP=2
      else
        GROUP=1
      fi
    fi
  else
    GROUP=$1
    MODE=$2
    STATUS=0
  fi
  if [ $STATUS -eq 0 ]; then
    if [ $MODE -eq 0 ]; then
      clear_config_var hdmi_force_hotplug $CONFIG
      clear_config_var hdmi_group $CONFIG
      clear_config_var hdmi_mode $CONFIG
    else
      set_config_var hdmi_force_hotplug 1 $CONFIG
      set_config_var hdmi_group $GROUP $CONFIG
      set_config_var hdmi_mode $MODE $CONFIG
    fi
    if [ "$INTERACTIVE" = True ]; then
      if [ $MODE -eq 0 ] ; then
        whiptail --msgbox "分辨率已设置为默认" 20 60 1
      else
        whiptail --msgbox "分辨率已设置为 $GRS 模式 $MODE" 20 60 1
      fi
    fi
    if [ $MODE -eq 0 ] ; then
      TSET="默认"
    elif [ $GROUP -eq 2 ] ; then
      TSET="DMT 模式 "$MODE
    else
      TSET="CEA 模式 "$MODE
    fi
    if [ "$TSET" != "$CSET" ] ; then
      ASK_TO_REBOOT=1
    fi
  fi
}

get_vnc_resolution() {
  if is_wayfire ; then
    W=$(grep ^headless_width $WAYFIRE_FILE | grep -o "[0-9]*")
    H=$(grep ^headless_height $WAYFIRE_FILE | grep -o "[0-9]*")
    if [ -n "$W" ] && [ -n "$H" ] ; then
      echo $W"x"$H
    else
      echo "1280x720"
    fi
  else
    if [ -e /etc/xdg/autostart/vnc_xrandr.desktop ] ; then
      grep fb /etc/xdg/autostart/vnc_xrandr.desktop | cut -f 15 -d ' '
    else
      echo ""
    fi
  fi
}

do_vnc_resolution() {
  if [ "$INTERACTIVE" = True ]; then
    CUR=$(get_vnc_resolution)
    if [ "$CUR" = "" ] ; then
      CUR=640x480
    fi
    FUN=$(whiptail --title "树莓派软件配置工具 (raspi-config)" --default-item $CUR --menu "设置 VNC 分辨率" $WT_HEIGHT $WT_WIDTH $WT_MENU_HEIGHT --cancel-button 返回 --ok-button 选择 \
      "640x480" "" "720x480" "" "800x600" "" "1024x768" "" "1280x720" "" "1280x1024" "" "1600x1200" "" "1920x1080" "" 3>&1 1>&2 2>&3)
    RET=$?
  else
    FUN=$1
    RET=0
  fi
  if [ $RET -eq 1 ]; then
    return 0
  elif [ $RET -eq 0 ]; then
    if is_wayfire ; then
      W=$(echo "$FUN" | cut -d x -f 1)
      H=$(echo "$FUN" | cut -d x -f 2)
      if grep -q ^headless_width $WAYFIRE_FILE ; then
        sed -i "s/headless_width.*/headless_width = $W/" $WAYFIRE_FILE
        sed -i "s/headless_height.*/headless_height = $H/" $WAYFIRE_FILE
      else
        if grep -q "\[output\]" $WAYFIRE_FILE ; then
          sed -i "s/\[output]/[output]\nheadless_width = $W\nheadless_height = $H/" $WAYFIRE_FILE
        else
          printf '\n[output]\nheadless_width = %d\nheadless_height = %d\n' "$W" "$H" >> $WAYFIRE_FILE
        fi
      fi
    else
      cat > /etc/xdg/autostart/vnc_xrandr.desktop << EOF
[Desktop Entry]
Type=Application
Name=vnc_xrandr
Comment=为 VNC 设置分辨率
NoDisplay=true
Exec=sh -c "if ! (xrandr | grep -q -w connected) ; then /usr/bin/xrandr --fb $FUN ; fi"
EOF
    fi
    if [ "$INTERACTIVE" = True ]; then
      whiptail --msgbox "分辨率已设置为 $FUN" 20 60 1
      ASK_TO_REBOOT=1
    fi
  fi
}

list_wlan_interfaces() {
  for dir in /sys/class/net/*/wireless; do
    if [ -d "$dir" ]; then
      IFACE="$(basename "$(dirname "$dir")")"
      if wpa_cli -i "$IFACE" status > /dev/null 2>&1; then
        echo "$IFACE"
      fi
    fi
  done
}

do_wifi_ssid_passphrase() {
  RET=0
  if [ "$INTERACTIVE" = True ] && [ -z "$(get_wifi_country)" ]; then
    do_wifi_country
  fi

  if systemctl -q is-active dhcpcd; then
    IFACE="$(list_wlan_interfaces | head -n 1)"

    if [ -z "$IFACE" ]; then
      if [ "$INTERACTIVE" = True ]; then
        whiptail --msgbox "未找到无线接口" 20 60
      fi
      return 1
    fi

    if ! wpa_cli -i "$IFACE" status > /dev/null 2>&1; then
      if [ "$INTERACTIVE" = True ]; then
        whiptail --msgbox "无法与 wpa_supplicant 通信" 20 60
      fi
      return 1
    fi
  elif ! systemctl -q is-active NetworkManager; then
    if [ "$INTERACTIVE" = True ]; then
        whiptail --msgbox "未找到支持的网络连接管理器" 20 60
      fi
      return 1
  fi

  SSID="$1"

  while [ -z "$SSID" ] && [ "$INTERACTIVE" = True ]; do
    if ! SSID=$(whiptail --inputbox "请输入 SSID" 20 60 3>&1 1>&2 2>&3); then
      return 0
    elif [ -z "$SSID" ]; then
      whiptail --msgbox "SSID 不能为空。请重试。" 20 60
    fi
  done

  PASSPHRASE="$2"
  while [ "$INTERACTIVE" = True ]; do
    if ! PASSPHRASE=$(whiptail --passwordbox "请输入密码。如果没有密码请留空。" 20 60 3>&1 1>&2 2>&3); then
      return 0
    else
      break
    fi
  done

  # 转义特殊字符以便嵌入到下面的正则表达式中
  ssid="$(echo "$SSID" \
   | sed 's;\\;\\\\;g' \
   | sed -e 's;\.;\\\.;g' \
         -e 's;\*;\\\*;g' \
         -e 's;\+;\\\+;g' \
         -e 's;\?;\\\?;g' \
         -e 's;\^;\\\^;g' \
         -e 's;\$;\\\$;g' \
         -e 's;\/;\\\/;g' \
         -e 's;\[;\\\[;g' \
         -e 's;\];\\\];g' \
         -e 's;{;\\{;g'   \
         -e 's;};\\};g'   \
         -e 's;(;\\(;g'   \
         -e 's;);\\);g'   \
         -e 's;";\\\\\";g')"

  HIDDEN=${3:-0}
  PLAIN=${4:-1}

  if systemctl -q is-active dhcpcd; then
    wpa_cli -i "$IFACE" list_networks \
     | tail -n +2 | cut -f -2 | grep -P "\t$ssid$" | cut -f1 \
     | while read -r ID; do
      wpa_cli -i "$IFACE" remove_network "$ID" > /dev/null 2>&1
    done

    ID="$(wpa_cli -i "$IFACE" add_network)"
    wpa_cli -i "$IFACE" set_network "$ID" ssid "\"$SSID\"" 2>&1 | grep -q "OK"
    RET=$((RET + $?))

    if [ -z "$PASSPHRASE" ]; then
      wpa_cli -i "$IFACE" set_network "$ID" key_mgmt NONE 2>&1 | grep -q "OK"
      RET=$((RET + $?))
    else
      if [ "$PLAIN" = 1 ]; then
        PASSPHRASE="\"$PASSPHRASE\""
      fi
      wpa_cli -i "$IFACE" set_network "$ID" psk "$PASSPHRASE" 2>&1 | grep -q "OK"
      RET=$((RET + $?))
    fi
    if [ "$HIDDEN" -ne 0 ]; then
      wpa_cli -i "$IFACE" set_network "$ID" scan_ssid 1 2>&1 | grep -q "OK"
      RET=$((RET + $?))
    fi
    if [ $RET -eq 0 ]; then
      wpa_cli -i "$IFACE" enable_network "$ID" > /dev/null 2>&1
    else
      wpa_cli -i "$IFACE" remove_network "$ID" > /dev/null 2>&1
      if [ "$INTERACTIVE" = True ]; then
        whiptail --msgbox "设置 SSID 或密码失败" 20 60
      fi
    fi
    wpa_cli -i "$IFACE" save_config > /dev/null 2>&1
    echo "$IFACE_LIST" | while read -r IFACE; do
      wpa_cli -i "$IFACE" reconfigure > /dev/null 2>&1
    done
  else
    IFACE="$(list_wlan_interfaces | head -n 1)"
    if [ "$HIDDEN" -ne 0 ]; then
      nmcli device wifi connect "$SSID" password "$PASSPHRASE" ifname "${IFACE}" hidden true | grep -q "activated"
    else
      nmcli device wifi connect "$SSID" password "$PASSPHRASE" ifname "${IFACE}" | grep -q "activated"
    fi
    RET=$((RET + $?))
  fi

  return "$RET"
}

get_wifi_power_save() {
  # 检查配置文件是否存在（更简单的方法）
  if [ -f /etc/NetworkManager/conf.d/default-wifi-powersave-off.conf ]; then
    echo 0  # 省电已禁用
  else
    echo 1  # 省电已启用（默认）
  fi
}

# shellcheck disable=SC2120
do_wifi_power_save() {
  DEFAULT=
  CURRENT=0
  if [ "$(get_wifi_power_save)" -eq 0 ]; then
    DEFAULT=--defaultno
    CURRENT=1
  fi

  if [ "$INTERACTIVE" = True ]; then
    whiptail --yesno "您想启用 WLAN 省电模式吗？\n\n注意：禁用省电模式可能会提高连接稳定性，但会增加功耗。" $DEFAULT 20 70 2
    RET=$?
  else
    RET=$1
  fi

  # 如果不存在则创建 NetworkManager conf.d 目录
  mkdir -p /etc/NetworkManager/conf.d

  if [ "$RET" -eq 0 ]; then
    # 启用省电 - 删除配置文件
    rm -f /etc/NetworkManager/conf.d/default-wifi-powersave-off.conf
    STATUS="已启用"
  elif [ "$RET" -eq 1 ]; then
    # 禁用省电 - 创建配置文件
    cat > /etc/NetworkManager/conf.d/default-wifi-powersave-off.conf << EOF
[connection]
wifi.powersave = 2
EOF
    STATUS="已禁用"
  else
    return "$RET"
  fi

  # 重新加载 NetworkManager 配置以保持持久性
  if systemctl -q is-active NetworkManager; then
    systemctl reload NetworkManager 2>/dev/null || true
  fi

  # 立即将更改应用到当前接口
  IFACE="$(list_wlan_interfaces | head -n 1)"
  if [ -n "$IFACE" ] && command -v iw >/dev/null 2>&1; then
    if [ "$RET" -eq 0 ]; then
      iw dev "$IFACE" set power_save on 2>/dev/null || true
    else
      iw dev "$IFACE" set power_save off 2>/dev/null || true
    fi
  fi

  if [ "$INTERACTIVE" = True ]; then
    whiptail --msgbox "WLAN 省电模式已$STATUS\n\n更改已立即应用，并对未来的连接保持持久。" 20 75 1
  fi
}

get_link_local_fallback() {
  # 检查配置文件是否存在
  if [ -f /etc/NetworkManager/conf.d/link-local.conf ]; then
    echo 1  # 链路本地回退已启用
  else
    echo 0  # 链路本地回退已禁用（默认）
  fi
}

# shellcheck disable=SC2120
do_link_local_fallback() {
  DEFAULT=--defaultno
  CURRENT=$(get_link_local_fallback)
  if [ "$CURRENT" -eq 1 ]; then
    DEFAULT=
  fi

  if [ "$INTERACTIVE" = True ]; then
    whiptail --yesno "您想启用链路本地回退吗？\n\n注意：这会在尝试 DHCP 之前立即分配 169.254.x.x 地址。仅在您了解此行为时启用。" $DEFAULT 20 75 2
    RET=$?
  else
    RET=$1
  fi

  if [ "$RET" -eq 0 ]; then
    STATUS="已启用"
  else
    STATUS="已禁用"
  fi

  # 仅在设置实际更改时进行更改
  if [ "$RET" -eq 0 ] && [ "$CURRENT" -eq 0 ]; then
    # 启用链路本地回退
    mkdir -p /etc/NetworkManager/conf.d
    cat > /etc/NetworkManager/conf.d/link-local.conf << EOF
# 由 raspi-config 创建/管理
[connection]
ipv4.link-local=4
EOF
    ASK_TO_REBOOT=1
  elif [ "$RET" -eq 1 ] && [ "$CURRENT" -eq 1 ]; then
    # 禁用链路本地回退
    rm -f /etc/NetworkManager/conf.d/link-local.conf
    ASK_TO_REBOOT=1
  fi

  # 重新加载 NetworkManager 配置以保持持久性
  if systemctl -q is-active NetworkManager; then
    systemctl reload NetworkManager 2>/dev/null || true
  fi

  if [ "$INTERACTIVE" = True ]; then
    whiptail --msgbox "链路本地回退已$STATUS" 20 60 1
  fi
}

do_finish() {
  disable_raspi_config_at_boot
  if [ $ASK_TO_REBOOT -eq 1 ]; then
    whiptail --yesno "您想现在重启吗？" 20 60 2
    if [ $? -eq 0 ]; then # 是
      sync
      reboot
    fi
  fi
  exit 0
}

