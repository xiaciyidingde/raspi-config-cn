do_squeekboard() {
  if [ "$INTERACTIVE" = True ]; then
    OPT=$(whiptail --title "树莓派软件配置工具 (raspi-config)" --menu "屏幕键盘" $WT_HEIGHT $WT_WIDTH $WT_MENU_HEIGHT \
      "S1 始终开启" "屏幕键盘始终启用" \
      "S2 自动检测" "如果找到触摸设备则启用屏幕键盘" \
      "S3 始终关闭" "屏幕键盘已禁用" \
      3>&1 1>&2 2>&3)
  else
    OPT=$1
    true
  fi
  GFILE="/etc/xdg/labwc-greeter/autostart"
  if [ ! -e $GFILE ] ; then
    GFILE="/usr/share/labwc/autostart"
  fi
  case "$OPT" in
    S1*)
      is_installed squeekboard || apt-get install -y squeekboard
      cat > /etc/xdg/autostart/squeekboard.desktop << EOF
[Desktop Entry]
Name=Squeekboard
Comment=启动屏幕键盘
Exec=/usr/bin/sbout
Terminal=false
Type=Application
NoDisplay=true
EOF
      sed -i '/sbtest/d' $GFILE
      if ! grep -q sbout $GFILE ; then
        echo "/usr/bin/sbout &" >> $GFILE
      fi
      PREFIX=""
      if [ -n "$SUDO_USER" ] ; then
        PREFIX="sudo -u $USER XDG_RUNTIME_DIR=/run/user/$SUDO_UID DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$SUDO_UID/bus "
      fi
      $PREFIX sbout > /dev/null 2> /dev/null &
      STATUS="已启用"
      ;;
    S2*)
      is_installed squeekboard || apt-get install -y squeekboard
      cat > /etc/xdg/autostart/squeekboard.desktop << EOF
[Desktop Entry]
Name=Squeekboard
Comment=启动屏幕键盘
Exec=/usr/bin/sbtest
Terminal=false
Type=Application
NoDisplay=true
EOF
      sed -i '/sbout/d' $GFILE
      if ! grep -q sbtest $GFILE ; then
        echo "/usr/bin/sbtest &" >> $GFILE
      fi
      PREFIX=""
      if [ -n "$SUDO_USER" ] ; then
        PREFIX="sudo -u $USER XDG_RUNTIME_DIR=/run/user/$SUDO_UID DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$SUDO_UID/bus "
      fi
      pkill squeekboard
      $PREFIX sbtest > /dev/null 2> /dev/null &
      STATUS="使用自动检测"
      ;;
    S3*)
      pkill squeekboard
      rm -f /etc/xdg/autostart/squeekboard.desktop
      sed -i '/sbout/d' $GFILE
      sed -i '/sbtest/d' $GFILE
      STATUS="已禁用"
      ;;
    *)
      return $OPT
      ;;
  esac
  if [ "$INTERACTIVE" = True ]; then
    whiptail --msgbox "屏幕键盘已$STATUS" 20 60 1
  fi
}

